# Copia este archivo a local/.env. Nunca subas local/.env al repositorio.
# Los valores siguientes son exclusivos para el entorno local de Docker.

# Puertos expuestos en tu equipo
BACKEND_PORT=8000
FRONTEND_PORT=5173
POSTGRES_PORT=5432
REDIS_PORT=6379
OCR_PORT=8011
FACE_PORT=8012
ROUTES_AI_PORT=8013

# Base de datos de desarrollo (no usar en produccion)
POSTGRES_USER=apuradito_user
POSTGRES_PASSWORD=apuradito_pass_dev
POSTGRES_DB=apuradito_db

# Genera un valor unico antes de iniciar. PowerShell:
# [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
LOCAL_SECRET_KEY=REEMPLAZA_ESTE_VALOR_POR_UN_SECRETO_ALEATORIO_DE_AL_MENOS_32_CARACTERES
AI_SERVICE_TOKEN=REEMPLAZA_POR_UN_TOKEN_ALEATORIO_COMPARTIDO_CON_LOS_SERVICIOS_IA

# Los motores completos requieren más memoria. Para un equipo limitado puedes
# usar los fallbacks explícitos: OCR_ENGINE=tesseract y FACE_ENGINE=opencv.
OCR_ENGINE=easyocr
FACE_ENGINE=face_recognition
