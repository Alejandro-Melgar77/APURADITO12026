# ============================================
# APURADITO - Variables de Entorno
# Copiar como .env y completar los valores
# ============================================

# Entorno: local | production
ENVIRONMENT=local

# Base de datos LOCAL (Docker)
DATABASE_URL_LOCAL=postgresql+asyncpg://apuradito_user:apuradito_pass_dev@localhost:5432/apuradito_db

# Base de datos PRODUCCIÓN (Supabase - completar cuando se cree el proyecto)
DATABASE_URL_PRODUCTION=postgresql+asyncpg://postgres:[PASSWORD]@[HOST].supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# JWT
SECRET_KEY=cambia_esta_clave_secreta_en_produccion_minimo_32_caracteres
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Firebase (para validar tokens de Google)
FIREBASE_PROJECT_ID=tu_proyecto_firebase

# Email (para recuperación de contraseñas - usar SMTP gratuito)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=apuradito.app@gmail.com
SMTP_PASSWORD=tu_app_password_de_gmail
EMAIL_FROM=Apuradito <apuradito.app@gmail.com>

# Configuración de la app
APP_NAME=Apuradito
APP_VERSION=1.0.0
DEBUG=true
